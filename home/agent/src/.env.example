# TikAPI Configuration
# Get your API key from https://tikapi.io/
TIKAPI_KEY=your_tikapi_key_here

# Next Auth Configuration  
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Database Configuration
DATABASE_URL="your_database_url_here"

# Error Logging Configuration
# Set to 'true' to enable verbose error logging (includes stack traces, request details, etc.)
# Set to 'false' for minimal error logging (recommended for production)
ERROR_LOGGING_VERBOSE=false
